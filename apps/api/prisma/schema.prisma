generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GameType {
  ROULETTE
  CSGO
  RIFTBOUND
  SUMMONERS_WAR
}

model Bets {
  id            String   @id @default(cuid())
  userId        String?
  gameType      GameType
  betAmount     Float
  profit        Float
  createdAt     DateTime @default(now())
  details       Json
  sessionId     String?
}